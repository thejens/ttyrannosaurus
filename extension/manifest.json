{
  "manifest_version": 3,
  "name": "ttyrannosaurus",
  "version": "1.0.0",
  "description": "Terminal sessions in Chrome tabs. Press ! in the address bar.",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": ["http://localhost:7071/*", "http://127.0.0.1:7071/*"],
  "omnibox": { "keyword": "!" },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open ttyrannosaurus sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [{
    "matches": ["http://127.0.0.1:7071/*"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
